---
import type { AstroComponent } from '@lucide/astro';
import type { HTMLAttributes } from 'astro/types';
import { css } from 'styled-system/css';

interface Props extends HTMLAttributes<'a'> {
  icon: AstroComponent;
  hoverColor?: 'blue' | 'purple';
}

const { icon: IconComponent, hoverColor = 'blue', ...rest } = Astro.props;

const base = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '2',
  paddingX: '4',
  paddingY: '2',
  bg: 'bgDim',
  borderWidth: '1px',
  borderStyle: 'solid',
  borderColor: 'border',
  borderRadius: 'md',
  fontSize: 'sm',
  color: 'fg',
  textDecoration: 'none',
  transitionProperty: 'border-color, color',
  transitionDuration: 'fast',
  transitionTimingFunction: 'default',
});

const hoverBlue = css({
  _hover: {
    borderColor: 'accentBlue',
    color: 'accentBlue',
  },
});

const hoverPurple = css({
  _hover: {
    borderColor: 'accentPurple',
    color: 'accentPurple',
  },
});

const iconClass = css({
  width: '4',
  height: '4',
});

const label = css({
  color: 'fgDim',
});
---

<a
  class:list={[base, hoverColor === 'purple' ? hoverPurple : hoverBlue]}
  {...rest}
>
  <IconComponent class={iconClass} />
  <span class={label}><slot /></span>
</a>
