---
import { css } from 'styled-system/css';

interface Props {
  path: string;
}

const { path } = Astro.props;

const shell = css({
  bg: 'bgDim',
  borderWidth: '1px',
  borderStyle: 'solid',
  borderColor: 'border',
  borderRadius: 'lg',
  overflow: 'hidden',
  boxShadow: '0 4px 20px rgba(0, 0, 0, 0.3)',
});

const titleBar = css({
  bg: 'bgDimmer',
  px: '4',
  py: '2.5',
  display: 'flex',
  alignItems: 'center',
  gap: '2',
  borderBottomWidth: '1px',
  borderBottomStyle: 'solid',
  borderColor: 'border',
});

const dot = css({
  width: '3',
  height: '3',
  borderRadius: 'full',
});

const pathLabel = css({
  marginLeft: 'auto',
  fontSize: 'xs',
  color: 'fgDim',
});
---

<div class={shell}>
  <div class={titleBar}>
    <span class={dot} style="background-color:#cc241d"></span>
    <span class={dot} style="background-color:#d79921"></span>
    <span class={dot} style="background-color:#98971a"></span>
    <span class={pathLabel}>thekorn.dev: {path}</span>
  </div>
  <slot />
</div>
