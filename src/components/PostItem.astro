---
import type { CollectionEntry } from 'astro:content';
import { css } from 'styled-system/css';
import Icon from './LucideIcon.astro';
import { isLucidIcon } from '../types';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const formattedDate = post.data.pubDate.toLocaleDateString('en-gb', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});

const formattedTime = post.data.pubDate.toLocaleTimeString('en-gb', {
  hour: '2-digit',
  minute: '2-digit',
});

const item = css({
  marginBottom: '2',
});

const link = css({
  display: 'flex',
  alignItems: 'center',
  gap: '3',
  padding: '3',
  bg: 'bg',
  borderWidth: '1px',
  borderStyle: 'solid',
  borderColor: 'transparent',
  borderRadius: 'md',
  textDecoration: 'none',
  color: 'inherit',
  transitionProperty: 'border-color, background-color',
  transitionDuration: 'fast',
  transitionTimingFunction: 'default',
  _hover: {
    borderColor: 'accent',
    bg: 'bgDim',
  },
});

const user = css({
  color: 'gruvbox.yellow',
});

const meta = css({
  fontSize: 'sm',
  color: 'gruvbox.blue',
});

const title = css({
  flex: '1',
  color: 'fg1',
});
---

<li class={item}>
  <a href={`/blog/${post.id}/`} class={link}>
    <span class={user}>thekorn</span>
    <span class={meta}>
      {formattedDate}
      {formattedTime}
    </span>
    {post.data.icon && isLucidIcon(post.data.icon) && <Icon name={post.data.icon} size={16} />}
    <span class={title}>{post.data.title}</span>
  </a>
</li>
