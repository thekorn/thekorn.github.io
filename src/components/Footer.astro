---
import { css } from 'styled-system/css';

interface Props {
  marker?: '←' | '❮';
}

const { marker = '←' } = Astro.props;

const wrap = css({
  marginTop: '10',
  paddingTop: '6',
  borderTopWidth: '1px',
  borderTopStyle: 'solid',
  borderColor: 'border',
});

const link = css({
  display: 'inline-flex',
  alignItems: 'center',
  gap: '2',
  fontSize: 'sm',
  color: 'fgDim',
  textDecoration: 'none',
  transitionProperty: 'color',
  transitionDuration: 'fast',
  transitionTimingFunction: 'default',
  _hover: {
    color: 'accentAlt',
  },
});

const markerSpan = css({
  color: 'accentPurple',
});
---

<div class={wrap}>
  <a href="/" class={link}>
    <span class={markerSpan}>{marker}</span><slot />
  </a>
</div>
