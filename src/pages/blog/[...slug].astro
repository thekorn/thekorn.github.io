---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { css } from 'styled-system/css';
import Layout from '@layouts/Layout.astro';
import { blogWebsite, getArticleSchema } from '@utils/structuredData';
import LayoutShell from '@components/LayoutShell.astro';
import Footer from '@components/Footer.astro';

type Props = CollectionEntry<'blog'>;

const post = Astro.props;

const articleStructuredData = getArticleSchema(post);

const breadcrumbsStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Blog',
      item: `${import.meta.env.SITE}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: post.data.title,
      item: `${import.meta.env.SITE}/blog/${post.id}/`,
    },
  ],
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [articleStructuredData, breadcrumbsStructuredData, blogWebsite],
};

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    if (import.meta.env.PROD) {
      return !data.draft;
    }
    return true;
  });
  return posts.map((p) => ({
    params: { slug: p.id },
    props: p,
  }));
}
const { Content } = await render(post);

const container = css({
  padding: '6',
});

const articleHeader = css({
  marginBottom: '8',
});

const postTitle = css({
  fontSize: '2xl',
  fontWeight: 'bold',
  color: 'fg0',
  margin: '0',
  '&::before': {
    content: '"$"',
    color: 'accent',
    marginRight: '1',
  },
});

const pubDate = css({
  fontSize: 'sm',
  color: 'fgDim',
});
---

<Layout title={`${post.data.title} | thekorn.dev`}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <LayoutShell path={`~/blog/${post.id}`}>
    <div class={container}>
      <article class="prose">
        <header class={articleHeader}>
          <h1 class={postTitle}>
            {post.data.title}
          </h1>
          <time class={pubDate}>
            Last commit:
            {
              post.data.pubDate.toLocaleDateString('en-us', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })
            }
          </time>
        </header>
        <Content />
      </article>
      <Footer>cd ~</Footer>
    </div>
  </LayoutShell>
</Layout>
